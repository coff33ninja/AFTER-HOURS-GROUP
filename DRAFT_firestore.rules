rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'status', 'createdAt']) && 
             data.email is string && data.email.size() <= 200 &&
             data.status is string && data.status.size() <= 20 &&
             data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && 
                       request.auth.uid == userId && 
                       isValidId(userId) &&
                       isValidUser(incoming());
      allow update: if isSignedIn() && 
                       request.auth.uid == userId && 
                       isValidId(userId) &&
                       incoming().diff(existing()).affectedKeys().hasOnly([]) && // Immutable for now
                       incoming().createdAt == existing().createdAt;
    }
  }
}
