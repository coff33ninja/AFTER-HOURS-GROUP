rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'status', 'createdAt']) && 
             data.email is string && data.email.size() <= 200 &&
             data.status is string && data.status.size() <= 20 &&
             data.createdAt == request.time;
    }

    function isValidAssociate(data) {
      return data.keys().hasAll(['name', 'focus', 'location', 'style', 'languages', 'traits', 'bio', 'quirks']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.focus is string && data.focus.size() <= 100 &&
             data.location is string && data.location.size() <= 100 &&
             data.style is string && data.style.size() <= 200 &&
             data.languages is string && data.languages.size() <= 200 &&
             data.traits is string && data.traits.size() <= 500 &&
             data.bio is string && data.bio.size() <= 5000 &&
             data.quirks is string && data.quirks.size() <= 5000;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow create: if isSignedIn() && 
                       request.auth.uid == userId && 
                       isValidId(userId) &&
                       isValidUser(incoming());
      allow update: if false; // Users can't update their own profile for now to maintain status security
    }

    match /associates/{associateId} {
      allow get, list: if isSignedIn(); // Any verified client can view the roster
      allow create: if isSignedIn() && isValidAssociate(incoming()) && isValidId(associateId);
      allow update, delete: if false; // Immutable unless admin
    }
  }
}
